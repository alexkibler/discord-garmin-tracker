# Copy this file to .env and fill in your values.

# ------------------------------------------------------------------
# Discord
# ------------------------------------------------------------------
# Bot token from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your-discord-bot-token-here

# ------------------------------------------------------------------
# Gmail
# ------------------------------------------------------------------
# The Gmail address you want to monitor
GMAIL_ADDRESS=your-gmail@gmail.com

# A Google App Password (not your regular account password).
# Generate one at: https://myaccount.google.com/apppasswords
# (requires 2-Step Verification to be enabled on the account)
GMAIL_APP_PASSWORD=your-app-password-here

# ------------------------------------------------------------------
# Optional
# ------------------------------------------------------------------
# How often to check Gmail for new emails, in seconds (default: 60)
# POLL_INTERVAL=60

# Logging level: DEBUG, INFO, WARNING, ERROR (default: INFO)
# LOG_LEVEL=INFO

# Path inside the container where guild config is stored (default: /data/config.json)
# CONFIG_PATH=/data/config.json
